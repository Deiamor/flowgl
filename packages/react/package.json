{
  "name": "@flowgl/react",
  "version": "0.8.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "React wrapper for @flowgl/core WebGL flowchart",
  "keywords": [
    "flowchart",
    "webgl",
    "react",
    "diagram",
    "graph"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/flowchart-react.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flowchart-react.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "sbom.json"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@flowgl/core": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rollup": "^4.18.0",
    "tslib": "^2.6.3",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:dev": "rollup -c rollup.config.mjs --environment MODE:development",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Deiamor/flowgl.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Deiamor/flowgl#readme",
  "bugs": {
    "url": "https://github.com/Deiamor/flowgl/issues"
  }
}
