{
  "name": "@flowgl/react",
  "version": "0.1.1",
  "description": "React wrapper for @flowgl/core WebGL flowchart",
  "keywords": [
    "flowchart",
    "webgl",
    "react",
    "diagram",
    "graph"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/flowchart-react.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flowchart-react.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@flowgl/core": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "rollup": "^4.18.0",
    "tslib": "^2.6.3",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:dev": "rollup -c rollup.config.mjs --environment MODE:development",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  }
}
