{
  "name": "@flowgl/svelte",
  "version": "0.9.1",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Svelte wrapper for @flowgl/core WebGL flowchart",
  "keywords": [
    "flowchart",
    "webgl",
    "svelte",
    "diagram",
    "graph"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/flowchart-svelte.esm.js",
  "svelte": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "import": "./dist/flowchart-svelte.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "sbom.json"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "svelte": ">=4.0"
  },
  "dependencies": {
    "@flowgl/core": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@testing-library/svelte": "^4.2.3",
    "happy-dom": "^20.9.0",
    "svelte": "^4.0.0",
    "svelte-check": "^3.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Deiamor/flowgl.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/Deiamor/flowgl#readme",
  "bugs": {
    "url": "https://github.com/Deiamor/flowgl/issues"
  }
}
