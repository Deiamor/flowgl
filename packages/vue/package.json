{
  "name": "@flowgl/vue",
  "version": "0.1.4",
  "description": "Vue 3 wrapper for @flowgl/core WebGL flowchart",
  "keywords": [
    "flowchart",
    "webgl",
    "vue",
    "vue3",
    "diagram",
    "graph"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/flowchart-vue.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flowchart-vue.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  },
  "dependencies": {
    "@flowgl/core": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  }
}
