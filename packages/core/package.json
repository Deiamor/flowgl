{
  "name": "@flowchart/core",
  "version": "0.1.0",
  "description": "Zero-dependency WebGL2 flowchart library",
  "keywords": ["flowchart", "webgl", "canvas", "diagram", "graph"],
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:dev": "rollup -c rollup.config.mjs --environment MODE:development",
    "dev": "rollup -c rollup.config.mjs --watch --environment MODE:development",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "happy-dom": "^20.9.0",
    "javascript-obfuscator": "^5.4.3",
    "rollup": "^4.18.0",
    "tslib": "^2.6.3",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
